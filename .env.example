# ==============================================================================
# SUNNY FOOTBALL ACADEMY - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Rename this file to .env and fill in the values.
# NEVER commit the actual .env file to Git!

# ─── BASE SETTINGS ────────────────────────────────────────────────────────────
PROJECT_NAME="Sunny Football Academy"
ENVIRONMENT=development # development or production
DEBUG=True
TZ=Europe/Chisinau
TIMEZONE=Europe/Chisinau

# ─── DATABASE (PostgreSQL) ───────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=football_academy
# Database URL for SQLAlchemy (Alembic/Backend)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ─── SECURITY ─────────────────────────────────────────────────────────────────
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=xK9mN2vL8qR5tY7wZ3bF6jH0pS4cD1aE9gU2iO5rT8yW
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# ─── CORS SETTINGS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:8080,http://127.0.0.1

# ─── REDIS (Caching & Rate Limiting) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# ─── PERFORMANCE ──────────────────────────────────────────────────────────────
UVICORN_WORKERS=1

# ─── GOOGLE SHEETS INTEGRATION ───────────────────────────────────────────────
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SPREADSHEET_ID=
# JSON content of the service account credentials file
GOOGLE_CREDENTIALS_JSON=

# ─── SMS SERVICES (Optional) ──────────────────────────────────────────────────
SMS_API_KEY=
SMS_SENDER=

# ─── FIREBASE (Push Notifications) ───────────────────────────────────────────
# JSON content of the firebase credentials file
FIREBASE_CREDENTIALS=

# ─── PAYMENTS (Stripe/Other) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── LOGGING ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
